# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# ==========================================
# Dependencies & Package Managers
# ==========================================
node_modules/
.pnpm-store/
npm-debug.*
yarn-debug.*
yarn-error.*

# ==========================================
# Expo & Build Outputs
# ==========================================
.expo/
.expo-shared/
.eas/
dist/
build/
web-build/
out-tsc/
*.tsbuildinfo
expo-env.d.ts

# ==========================================
# Native Folders & Binaries (Expo Prebuild / EAS)
# ==========================================
# Ignora le cartelle native in qualsiasi sotto-cartella del monorepo
**/android/
**/ios/

# Binari e Chiavi Native
*.apk
*.aab
*.ipa
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# ==========================================
# Environment & Local Configuration
# ==========================================
.env
.env.*
!.env.example

# ==========================================
# IDEs, Editors & Caches
# ==========================================
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

.cache/
.local/
.metro-health-check*
.vercel

# ==========================================
# System Files & Logs
# ==========================================
.DS_Store
Thumbs.db
*.log
coverage/
node_modules/
android/app/build/
android/.gradle/
android/.kotlin/
ios/build/
ios/Pods/
*.apk
*.aab
.expo/
dist/
